msgstr "Inställningar"

#: src/anpr_viewer/main.py:247
msgid "Export Log"
msgstr "Exportera logg"

#: src/anpr_viewer/main.py:248
msgid "Clear Log"
msgstr "Töm logg"

#: src/anpr_viewer/main.py:249
msgid "Copy Debug Info"
msgstr "Kopiera felsökningsinformation"

#: src/anpr_viewer/main.py:250
