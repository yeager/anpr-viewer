#: src/anpr_viewer/main.py:200
msgid ""
"Open a video file or drag & drop one here.\n"
"You can also enter a stream URL."
msgstr ""
"Öppna en videofil eller dra och släpp en här.\n"
"Du kan också ange en URL till strömmande video."

#: src/anpr_viewer/main.py:229
msgid "Detected Plates"
msgstr "Identifiera skyltar"

#: src/anpr_viewer/main.py:255
msgid "Ready"
msgstr "Redo"

#: src/anpr_viewer/main.py:304
msgid "Welcome"
msgstr "Välkommen"

#: src/anpr_viewer/main.py:310
msgid "Welcome to ANPR Viewer"
msgstr "Välkommen till ANPR-visare"

#: src/anpr_viewer/main.py:312
msgid ""
"Automatic license plate recognition from video.\\n\\n✓ Open video files or "
"live streams\\n✓ Drag & drop support\\n✓ Detected plates listed in real-"
"time\\n✓ Log results to file\\n✓ Export as CSV or JSON"
msgstr ""
"Automatisk identifiering av registreringsskyltar från video.\\n\\n✓ Öppna "
"videofiler eller direktströmmar\\n✓ Stöd för dra och släpp\\n✓ Detekterade "
"skyltar listas i realtid\\n✓ Logga resultat till fil\\n✓ Exportera som CSV "
"eller JSON"

#: src/anpr_viewer/main.py:320
msgid "Get Started"
msgstr "Kom igång"

