#: src/anpr_viewer/main.py:271
msgid "No video loaded"
msgstr "Ingen video inläst"

#: src/anpr_viewer/main.py:272
msgid ""
"Open a video file, connect a camera, or drag & drop.\n"
"You can also enter a stream URL."
msgstr ""
"Öppna en videofil, anslut en kamera eller dra och släpp.\n"
"Du kan också ange en strömnings-URL."

#: src/anpr_viewer/main.py:301
msgid "Detected Plates"
msgstr "Identifiera skyltar"

#: src/anpr_viewer/main.py:327
msgid "Ready"
msgstr "Redo"

#: src/anpr_viewer/main.py:376
msgid "Welcome"
msgstr "Välkommen"

#: src/anpr_viewer/main.py:382
msgid "Welcome to ANPR Viewer"
msgstr "Välkommen till ANPR-visare"

#: src/anpr_viewer/main.py:384
msgid ""
"Automatic license plate recognition from video.\\n\\n✓ Open video files or "
"live streams\\n✓ Live capture from webcams and USB cameras\\n✓ Drag & drop "
"support\\n✓ Detected plates listed in real-time\\n✓ Log results to file\\n✓ "
"Export as CSV or JSON"
msgstr ""
"Automatisk identifiering av registreringsskyltar från video.\\n\\n✓ Öppna "
"videofiler eller direktströmningar\\n✓ Direktinspelning från webbkameror och"
" USB-kameror\\n✓ Stöd för dra och släpp\\n✓ Detekterade skyltar listas i "
"realtid\\n✓ Logga resultat till fil\\n✓ Exportera som CSV eller JSON"

#: src/anpr_viewer/main.py:393
msgid "Get Started"
msgstr "Kom igång"

#: src/anpr_viewer/main.py:416
msgid "Open Video File"
msgstr "Öppna videofil"

#: src/anpr_viewer/main.py:418
msgid "Video files"
msgstr "Videofiler"

#: src/anpr_viewer/main.py:436
msgid "Open Video Stream"
msgstr "Öppna videoström"

#: src/anpr_viewer/main.py:437
msgid "Enter the URL of a video stream (RTSP, HTTP, etc.)"
msgstr "Ange URL-adressen till en videoström (RTSP, HTTP osv.)."

#: src/anpr_viewer/main.py:438 src/anpr_viewer/main.py:469
msgid "Cancel"
msgstr "Avbryt"

#: src/anpr_viewer/main.py:439 src/anpr_viewer/main.py:470
msgid "Open"
msgstr "Öppna"

#: src/anpr_viewer/main.py:459
msgid "No Video Devices"
msgstr "Inga videoenheter"

#: src/anpr_viewer/main.py:460
msgid ""
"No video capture devices were found.\n"
"Connect a webcam or USB camera and try again."
msgstr ""
"Inga videofångstenheter hittades.\n"
"Anslut en webbkamera eller USB-kamera och försök igen."

#: src/anpr_viewer/main.py:462
msgid "OK"
msgstr "OK"

#: src/anpr_viewer/main.py:467
msgid "Select Video Device"
msgstr "Välj videoenhet"

#: src/anpr_viewer/main.py:468
msgid "Choose a camera to use for live plate detection."
msgstr "Välj en kamera som ska användas för direktidentifiering av skyltar."

#: src/anpr_viewer/main.py:500
#, python-format
msgid "Live Camera — %s"
msgstr "Direktsänd kamera — %s"

#: src/anpr_viewer/main.py:501
msgid "Scanning for plates in real-time..."
msgstr "Söker efter skyltar i realtid..."

#: src/anpr_viewer/main.py:502 src/anpr_viewer/main.py:584
msgid "Stop"
msgstr "Stoppa"

#: src/anpr_viewer/main.py:539
#, python-format
msgid "Live scan — %(frames)d frames, %(count)d plates found"
msgstr "Direktidentifiering — %(frames)d bildrutor, %(count)d skyltar hittade"

#: src/anpr_viewer/main.py:555
#, python-format
msgid "Loaded: %s"
msgstr "Läste in: %s"

#: src/anpr_viewer/main.py:563
msgid "Stream loaded. Click 'Scan Video' to detect plates."
msgstr "Ström inläst. Klicka på ”Sök av video” för att upptäcka skyltar."

#: src/anpr_viewer/main.py:571
msgid "Video loaded. Click 'Scan Video' to detect plates."
msgstr "Video inläst. Klicka på ”Sök av video” för att upptäcka skyltar."

#: src/anpr_viewer/main.py:580
msgid "Scan stopped"
msgstr "Avsökning stoppad"

#: src/anpr_viewer/main.py:588
msgid "Scanning..."
msgstr "Söker av..."

#: src/anpr_viewer/main.py:635
#, python-format
msgid "Scanning... %(time).0fs / %(total).0fs — %(count)d plates found"
msgstr "Söker av... %(time).0fs / %(total).0fs — %(count)d skyltar hittade"

#: src/anpr_viewer/main.py:650
#, python-format
msgid "%(time)s — Scan complete. %(count)d plates in log."
msgstr "%(time)s — Avsökning klar. %(count)d skyltar loggades."

#: src/anpr_viewer/main.py:712
#, python-format
msgid "Copied: %s"
msgstr "Kopierade: %s"

#: src/anpr_viewer/main.py:766
msgid "OCR Engine"
msgstr "OCR-motor"

#: src/anpr_viewer/main.py:767
msgid "Engine"
msgstr "Motor"

#: src/anpr_viewer/main.py:773
msgid "Minimum Confidence (%)"
msgstr "Minsta konfidens (%)"

#: src/anpr_viewer/main.py:779
msgid "Region"
msgstr "Region"

#: src/anpr_viewer/main.py:780
msgid "Plate Format"
msgstr "Skyltformat"

#: src/anpr_viewer/main.py:786
msgid "Logging"
msgstr "Loggning"

#: src/anpr_viewer/main.py:787
msgid "Log detections to file"
msgstr "Logga upptäckter till fil"

#: src/anpr_viewer/main.py:799
msgid "Export Plate Log"
msgstr "Exportera skyltlogg"

#: src/anpr_viewer/main.py:813
#, python-format
msgid "Exported to %s"
msgstr "Exporterades till %s"

#: src/anpr_viewer/main.py:822
msgid "Log cleared"
msgstr "Loggen tömd"

#: src/anpr_viewer/main.py:838
msgid "Debug info copied"
msgstr "Felsökningsinformation kopierad"

#: src/anpr_viewer/main.py:844
msgid "General"
msgstr "Allmänt"

#: src/anpr_viewer/main.py:846
msgid "Quit"
msgstr "Avsluta"

#: src/anpr_viewer/main.py:847
msgid "Export log"
msgstr "Exportera logg"

#: src/anpr_viewer/main.py:848
msgid "Keyboard shortcuts"
msgstr "Tangentbordsgenvägar"

#: src/anpr_viewer/main.py:865
msgid ""
"Automatic license plate recognition from video files, streams, and cameras."
msgstr ""
"Automatisk identifiering av registreringsskyltar från videofiler, strömmar "
"och kameror."
